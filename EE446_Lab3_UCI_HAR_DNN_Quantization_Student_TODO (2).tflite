    "print(f\"Dynamic - Size: {size_dynamic:.1f} KB, Accuracy: {acc_dynamic:.4f}\")\n",
    "print(f\"Float16 - Size: {size_fp16:.1f} KB, Accuracy: {acc_fp16:.4f}\")\n",
    "print(f\"Int8    - Size: {size_int8:.1f} KB, Accuracy: {acc_int8:.4f}\")"
